# ============================================================================
# Environment Variables - Web Template
# ============================================================================
# העתק קובץ זה ל-.env.local והחלף את הערכים שלך
# Copy this file to .env.local and replace with your values
#
# קובץ .env.local לא עולה ל-Git (נמצא ב-.gitignore)
# .env.local files are gitignored for security

# ============================================================================
# Convex (חובה / Required)
# ============================================================================
# נוצר אוטומטית כשמריצים: bunx convex dev
# Auto-generated when running: bunx convex dev

CONVEX_DEPLOYMENT=dev:your-project-name-123
NEXT_PUBLIC_CONVEX_URL=https://your-project-name.convex.cloud

# ============================================================================
# Polar.sh - מערכת תשלומים (אופציונלי / Optional)
# ============================================================================
# נדרש רק אם אתם משתמשים במערכת התשלומים
# Only required if using the payment system
# ראה docs/POLAR_PAYMENTS_SETUP.md להוראות מלאות

# Organization ID מ-Polar Dashboard
# POLAR_ORGANIZATION_ID=your-organization-id

# Access Token (יצירה ב-Polar Dashboard → Settings → Personal Access Tokens)
# POLAR_ACCESS_TOKEN=polar_at_...

# Webhook Secret (יצירה ב-Polar Dashboard → Settings → Webhooks)
# POLAR_WEBHOOK_SECRET=whsec_...

# ============================================================================
# Site URL (נדרש ל-Production / Required for Production)
# ============================================================================
# כתובת האתר שלכם - נדרש לתשלומים ו-redirects
# Your site URL - required for payments and redirects

# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ============================================================================
# Google Gemini AI (נדרש לצ'אטבוט / Required for AI Chatbot)
# ============================================================================
# יצירה ב: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key
